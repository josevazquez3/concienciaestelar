# Neon / Vercel Postgres — mapeo de variables
#
# LOCAL (.env.local):
#   DATABASE_URL  ←  pooled (con -pooler en el host)
#   DIRECT_URL    ←  directa (sin -pooler)
#
# VERCEL (Settings → Environment Variables):
#   Si Neon está integrado, Vercel crea POSTGRES_* pero Prisma necesita:
#   DATABASE_URL  =  POSTGRES_PRISMA_URL
#   DIRECT_URL    =  POSTGRES_URL_NON_POOLING
#   AUTH_SECRET   =  secreto largo (openssl rand -base64 32)
#   AUTH_URL      =  https://tu-dominio.vercel.app
#
# Después de agregar variables: Redeploy en Vercel.
# Ejecutá migraciones en Neon (SQL Editor o scripts db:migrate*).

DATABASE_URL="postgresql://USUARIO:CLAVE@ep-XXXX-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USUARIO:CLAVE@ep-XXXX.REGION.aws.neon.tech/neondb?sslmode=require"

# NextAuth
AUTH_SECRET="genera-un-secreto-largo-aleatorio"
AUTH_URL="http://localhost:3000"

# Vercel Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
